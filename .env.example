APP_NAME=Recip
APP_ENV=local
APP_KEY=                          # Run: php artisan key:generate
APP_DEBUG=true                    # Production: false
APP_URL=http://localhost          # Production: https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                   # Production: error

# ── Database ────────────────────────────────────────────────
# In Docker, set DB_HOST to the service name (e.g. "db")
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=recip
DB_USERNAME=root
DB_PASSWORD=

# Used only by Docker MariaDB container for initial setup
DB_ROOT_PASSWORD=

# ── Session ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null               # Production: yourdomain.com
# SESSION_SECURE_COOKIE=true      # Production: uncomment

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── Mail (SMTP — works with any provider) ───────────────────
# Swap host/port/credentials to change providers. Zero code changes needed.
#
# Resend:      MAIL_HOST=smtp.resend.com  MAIL_PORT=465  MAIL_SCHEME=tls  MAIL_USERNAME=resend  MAIL_PASSWORD=re_xxxxx
# Mailgun:     MAIL_HOST=smtp.mailgun.org MAIL_PORT=587  MAIL_SCHEME=tls
# Self-hosted: MAIL_HOST=mail.yourdomain.com MAIL_PORT=587
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@recip.cooking"
MAIL_FROM_NAME="${APP_NAME}"

# ── Cloudflare Turnstile ───────────────────────────────────
# Get keys at https://dash.cloudflare.com → Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Cloudflare Tunnel (production only) ────────────────────
# Create tunnel: cloudflared tunnel create recip
# TUNNEL_TOKEN=

VITE_APP_NAME="${APP_NAME}"
TUNNEL_TOKEN=
