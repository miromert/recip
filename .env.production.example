# ── Recip — Production Environment ──────────────────────────
# Copy this to .env and fill in the values marked CHANGE_ME
# ────────────────────────────────────────────────────────────

APP_NAME=Recip
APP_ENV=production
APP_KEY=                          # Run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://recip.cooking     # CHANGE_ME: your domain

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database ────────────────────────────────────────────────
# In Docker, DB_HOST must match the service name in docker-compose.yml
DB_CONNECTION=mariadb
DB_HOST=db
DB_PORT=3306
DB_DATABASE=recip
DB_USERNAME=recip
DB_PASSWORD=CHANGE_ME             # CHANGE_ME: strong random password
DB_ROOT_PASSWORD=CHANGE_ME        # CHANGE_ME: strong random password (Docker MariaDB root)

# ── Session ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=recip.cooking      # CHANGE_ME: your domain (no https://)
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Mail (SMTP — works with any provider) ───────────────────
# Swap these 4 values to change providers. Zero code changes needed.
#
# Resend:      MAIL_HOST=smtp.resend.com  MAIL_PORT=465  MAIL_SCHEME=tls  MAIL_USERNAME=resend  MAIL_PASSWORD=re_xxxxx
# Mailgun:     MAIL_HOST=smtp.mailgun.org MAIL_PORT=587  MAIL_SCHEME=tls  MAIL_USERNAME=xxx     MAIL_PASSWORD=xxx
# Self-hosted: MAIL_HOST=mail.yourdomain.com MAIL_PORT=587 MAIL_SCHEME=null MAIL_USERNAME=xxx   MAIL_PASSWORD=xxx
#
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.resend.com         # CHANGE_ME: your SMTP host
MAIL_PORT=465                     # CHANGE_ME: 465 (TLS) or 587 (STARTTLS)
MAIL_USERNAME=resend              # CHANGE_ME: your SMTP username
MAIL_PASSWORD=re_xxxxx            # CHANGE_ME: your SMTP password / API key
MAIL_FROM_ADDRESS="noreply@recip.cooking"   # CHANGE_ME: your from address
MAIL_FROM_NAME="${APP_NAME}"

# ── Cloudflare Turnstile ────────────────────────────────────
# Get keys at https://dash.cloudflare.com → Turnstile
TURNSTILE_SITE_KEY=CHANGE_ME
TURNSTILE_SECRET_KEY=CHANGE_ME

# ── Cloudflare Tunnel ──────────────────────────────────────
# Create tunnel: cloudflared tunnel create recip
# Then grab the token from the dashboard or CLI
TUNNEL_TOKEN=CHANGE_ME

VITE_APP_NAME="${APP_NAME}"
